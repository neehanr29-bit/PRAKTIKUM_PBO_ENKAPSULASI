#PRAKTIKUM ENKAPULASI
class Hewan:
    def __init__(self, nama, umur):
        self.__nama = nama
        self.__umur = umur

    def get_info(self):
        print(f"Nama : {self.__nama}")
        print(f"Umur : {self.__umur} tahun")

    def get_nama(self):
        return {self.__nama} #nambahin method nama

    def get_umur(self):
        return {self.__umur} #nambahin method umur

hewan1 = Hewan("Alpin", 2)
hewan1.get_info()

print(hewan1.get_nama())
print(hewan1.get_umur())
